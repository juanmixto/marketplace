# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production

# vercel
.vercel

# user-uploaded images (LocalUploader writes here in dev/self-hosted)
/public/uploads/*
!/public/uploads/.gitkeep

# Generated service worker (built from public/sw.template.js on prebuild)
/public/sw.js

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# local test and runtime artifacts
/test-results/
/results.csv
/results.txt
/run.sh
/process_prs.sh
/services/telegram-sidecar/.venv/
/services/telegram-sidecar/app/__pycache__/
/services/telegram-sidecar/sessions/

# Local wiki source is published to the GitHub wiki repo separately
docs/wiki/
.claude/
