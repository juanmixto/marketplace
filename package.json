{
  "name": "marketplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "prisma generate && node --env-file-if-exists=.env --env-file-if-exists=.env.local ./node_modules/prisma/build/index.js migrate deploy && node ./scripts/build-sw.mjs",
    "dev": "next dev",
    "prebuild": "prisma generate && node ./scripts/build-sw.mjs",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "test": "node ./scripts/run-node-tests.mjs",
    "test:parallel": "node ./scripts/run-node-tests.mjs --parallel",
    "test:db": "node --env-file-if-exists=.env --env-file-if-exists=.env.test ./scripts/run-node-tests.mjs --db",
    "test:db:parallel": "node --env-file-if-exists=.env --env-file-if-exists=.env.test ./scripts/run-node-tests.mjs --db --parallel",
    "test:integration": "node --env-file-if-exists=.env --env-file-if-exists=.env.test ./scripts/run-integration-tests.mjs",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke --workers=1",
    "test:coverage": "c8 node ./scripts/run-node-tests.mjs --parallel",
    "verify": "node ./scripts/verify.mjs",
    "verify:posthog-proxy": "scripts/verify-posthog-proxy.sh",
    "typecheck": "tsc --noEmit",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "audit:admin-roles": "node ./scripts/audit-admin-role-helpers.mjs",
    "lint:fix": "eslint . --max-warnings=0 --fix",
    "lint:prune-suppressions": "eslint . --max-warnings=0 --prune-suppressions",
    "audit:app-env": "node ./scripts/audit-app-env-coherence.mjs",
    "audit:contracts": "node ./scripts/audit-domain-contracts.mjs",
    "audit:flags-cleanup": "node ./scripts/audit-flag-cleanup-tickets.mjs",
    "audit:fk": "node ./scripts/audit-fk-onDelete.mjs",
    "audit:findMany": "node ./scripts/audit-unbounded-findMany.mjs",
    "audit:form-number-coerce": "node ./scripts/audit-form-number-coerce.mjs",
    "audit:image-sizes": "node ./scripts/audit-image-sizes.mjs",
    "audit:status-write": "node ./scripts/audit-status-write.mjs",
    "audit:prisma-update-spread": "node ./scripts/audit-prisma-update-spread.mjs",
    "audit:string-no-max": "node ./scripts/audit-string-no-max.mjs",
    "audit:webhook-cast": "node ./scripts/audit-webhook-cast.mjs",
    "audit:no-root-env": "node ./scripts/audit-no-root-env.mjs",
    "audit:order-status-transitions": "node ./scripts/audit-order-status-transitions.mjs",
    "audit:admin-explicit-select": "node ./scripts/audit-admin-explicit-select.mjs",
    "audit:img-src": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/audit-img-src-usage.ts",
    "audit:deps": "npm audit --omit=dev --audit-level=high",
    "prisma:generate": "prisma generate",
    "db:migrate": "node --env-file-if-exists=.env --env-file-if-exists=.env.local ./node_modules/prisma/build/index.js migrate dev",
    "db:seed": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx prisma/seed.ts",
    "db:seed:stg": "scripts/staging-seed.sh",
    "db:seed:stg:reset": "scripts/staging-seed.sh --reset-demo",
    "prod:bootstrap": "node --import tsx scripts/prod-bootstrap.ts",
    "deploy:dev": "scripts/deploy-local-env.sh development",
    "deploy:stg": "scripts/deploy-local-env.sh staging",
    "deploy:prod": "scripts/deploy-local-env.sh production",
    "verify:public-envs": "scripts/verify-public-envs.sh",
    "db:clear-demo": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/clear-demo-data.ts",
    "db:studio": "node --env-file-if-exists=.env --env-file-if-exists=.env.local ./node_modules/prisma/build/index.js studio",
    "db:reset": "node --env-file-if-exists=.env --env-file-if-exists=.env.local ./node_modules/prisma/build/index.js migrate reset --force && npm run db:seed",
    "push:backfill-user-agent": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/backfill-push-subscription-user-agent.ts",
    "ingestion:rawjson-sweep": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/ingestion-rawjson-sweep.ts",
    "dlq:list": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/dlq-list.ts",
    "dlq:resolve": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/dlq-mark-resolved.ts",
    "reconcile:payments": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/reconcile-payments.ts",
    "notify:dispatch-pending": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/dispatch-pending-notifications.ts",
    "sendcloud:replay": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/sendcloud-replay.ts",
    "reports:reviews": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/review-reports-list.ts",
    "worker": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx src/workers/index.ts",
    "ingestion:sweep": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/ingestion-retention-sweep.ts",
    "ingestion:metrics": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/ingestion-metrics.ts",
    "sweep:orphans": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/sweep-orphan-blobs.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@floating-ui/react": "^0.27.19",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@react-email/components": "^1.0.12",
    "@sentry/nextjs": "^10.49.0",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.1.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "otplib": "^13.4.0",
    "pg": "^8.20.0",
    "pg-boss": "^10.4.2",
    "posthog-js": "^1.369.0",
    "posthog-node": "^5.21.2",
    "prisma": "^7.7.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "^5.2.10",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "hono": "^4.12.14"
  }
}
