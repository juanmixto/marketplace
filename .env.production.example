# Public origin
# Post-domain-migration default. During the 30-day coexistence window after
# the cutover, feldescloud.com keeps resolving via the same tunnel; only
# this canonical APP_HOST changes. See docs/runbooks/domain-migration.md.
APP_HOST=raizdirecta.es
AUTH_URL=https://raizdirecta.es
NEXT_PUBLIC_APP_URL=https://raizdirecta.es

# Environment dimension orthogonal to NODE_ENV (see #1087 / domain-migration
# Fase 5.2). Allowed: development | staging | production. Used by Sentry +
# PostHog tagging and by robots.ts to disallow indexing on staging.
APP_ENV=production

# Support inbox shown in transactional emails (e.g. magic-link footer).
# Was hardcoded to soporte@feldescloud.com pre-#1087.
SUPPORT_EMAIL=soporte@raizdirecta.es

# Comma-separated list of dev-tunnel hostnames that the Next.js dev server
# trusts as cross-origins (next.config.ts allowedDevOrigins) and that the
# service worker treats as dev hosts (public/sw.template.js DEV_HOSTNAMES).
# Templates ship the coexistence default; remove *.feldescloud.com at T+60.
# Not relevant in production runtime — kept here for parity with .env.example.
DEV_TUNNEL_HOSTS=*.raizdirecta.es,*.feldescloud.com

# Auth
AUTH_SECRET=generate-a-long-random-secret

# Google OAuth — provider is registered iff BOTH vars are set.
# Setup runbook: docs/auth/google-setup.md
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Database
POSTGRES_USER=mp_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=marketplace

# Runtime behavior
TRUST_PROXY_HEADERS=true
PAYMENT_PROVIDER=stripe

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_here
STRIPE_WEBHOOK_SECRET=whsec_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_here

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=put-your-tunnel-token-here

# DB resilience (#1002 — Phase 0).
# Used by host-side scripts only (scripts/db/*.sh, pgBackRest cron). NOT read by
# the Next.js app. Live values live in /etc/marketplace/backup.env (mode 600).
# Setup runbook: docs/runbooks/db-backup.md
# B2_KEY_ID=
# B2_APP_KEY=
# B2_REMOTE=b2-mp
# PGBACKREST_CIPHER_PASS=
# MP_DUMP_PASSPHRASE=
# HC_PING_DUMP_URL=
# HC_PING_PGBACKREST_URL=
# HC_PING_VERIFY_URL=
