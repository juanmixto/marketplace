# Public origin
APP_HOST=dev.feldescloud.com
AUTH_URL=https://dev.feldescloud.com
NEXT_PUBLIC_APP_URL=https://dev.feldescloud.com

# Deploy environment. Required pairing: server APP_ENV must match the
# browser mirror NEXT_PUBLIC_APP_ENV (webpack inlines the latter at build
# time). Sentry uses this for the environment tag; PostHog tags every
# event with `app_env`; staging deploys are blocked for crawlers in
# src/app/robots.ts. Values: "development" | "staging" | "production".
APP_ENV=production
NEXT_PUBLIC_APP_ENV=production

# Support inbox shown in auth fallback copy. Must be a deliverable address.
SUPPORT_EMAIL=soporte@your-domain.com

# Comma-separated wildcard hosts allowed to load the app via dev tunnel
# (next.config.ts allowedDevOrigins + service worker DEV_HOSTNAMES).
# Default already covers the migration coexistence window.
# DEV_TUNNEL_HOSTS=*.raizdirecta.es,*.feldescloud.com

# Auth
AUTH_SECRET=generate-a-long-random-secret

# Google OAuth — provider is registered iff BOTH vars are set.
# Setup runbook: docs/auth/google-setup.md
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Database
POSTGRES_USER=mp_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=marketplace

# Runtime behavior
TRUST_PROXY_HEADERS=true
PAYMENT_PROVIDER=stripe

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_here
STRIPE_WEBHOOK_SECRET=whsec_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_here

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=put-your-tunnel-token-here

# DB resilience (#1002 — Phase 0).
# Used by host-side scripts only (scripts/db/*.sh, pgBackRest cron). NOT read by
# the Next.js app. Live values live in /etc/marketplace/backup.env (mode 600).
# Setup runbook: docs/runbooks/db-backup.md
# B2_KEY_ID=
# B2_APP_KEY=
# B2_REMOTE=b2-mp
# PGBACKREST_CIPHER_PASS=
# MP_DUMP_PASSPHRASE=
# HC_PING_DUMP_URL=
# HC_PING_PGBACKREST_URL=
# HC_PING_VERIFY_URL=
