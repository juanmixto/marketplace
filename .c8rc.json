{
  "all": true,
  "include": [
    "src/domains/**/*.ts",
    "src/lib/**/*.ts"
  ],
  "exclude": [
    "src/generated/**",
    "src/domains/**/actions.ts",
    "src/domains/catalog/queries.ts",
    "src/domains/settlements/**",
    "src/domains/vendors/stripe.ts",
    "src/domains/shipping/calculator.ts",
    "src/domains/auth/email-verification.ts",
    "src/lib/auth.ts",
    "src/lib/cart-store.ts",
    "src/lib/constants.ts",
    "src/lib/db.ts",
    "src/lib/action-session.ts",
    "src/lib/auth-guard.ts",
    "src/lib/config.ts",
    "src/lib/email.ts",
    "src/lib/revalidate.ts",
    "src/lib/certification-info.ts"
  ],
  "reporter": [
    "text",
    "lcov",
    "html"
  ],
  "check-coverage": true,
  "lines": 70,
  "functions": 70,
  "branches": 65,
  "statements": 70
}
