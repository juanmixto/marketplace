# Public origin for Docker-based development preview.
APP_HOST=dev.raizdirecta.es
AUTH_URL=https://dev.raizdirecta.es
NEXT_PUBLIC_APP_URL=https://dev.raizdirecta.es
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development

# Auth
AUTH_SECRET=generate-a-long-random-secret

# Database. Keep separate from staging and production.
POSTGRES_USER=mp_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=marketplace_development

# Runtime behavior
TRUST_PROXY_HEADERS=true
PAYMENT_PROVIDER=stripe

# Stripe. Use Stripe test keys for development.
STRIPE_SECRET_KEY=sk_test_here
STRIPE_WEBHOOK_SECRET=whsec_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_here

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=put-your-development-tunnel-token-here
