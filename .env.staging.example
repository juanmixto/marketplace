# ===========================
# STAGING ENVIRONMENT TEMPLATE
# ===========================
# Plantilla para el `.env.staging` que vivirá en el host cuando se
# materialice staging (Fase 5 de docs/runbooks/domain-migration.md). NO
# comitear el archivo real con valores reales — sólo esta plantilla.
#
# Diferencias vs `.env.production.example`:
#   - APP_ENV / NEXT_PUBLIC_APP_ENV = "staging" → Sentry separa eventos,
#     PostHog tagea, robots.txt devuelve `Disallow: /`.
#   - Hosts apuntan a staging.raizdirecta.es.
#   - BD separada (marketplace_staging) en el mismo cluster Postgres.

# Public origin
APP_HOST=staging.raizdirecta.es
AUTH_URL=https://staging.raizdirecta.es
NEXT_PUBLIC_APP_URL=https://staging.raizdirecta.es

# Deploy environment — staging splits from production in observability.
APP_ENV=staging
NEXT_PUBLIC_APP_ENV=staging

# Auth
AUTH_SECRET=generate-a-long-random-secret

# Google OAuth — same client ID as prod, different redirect URI.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Database (separate DB on the shared cluster; pgBackRest covers it).
POSTGRES_USER=mp_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=marketplace_staging

# Runtime behavior
TRUST_PROXY_HEADERS=true
PAYMENT_PROVIDER=stripe

# Stripe — TEST keys only in staging.
STRIPE_SECRET_KEY=sk_test_here
STRIPE_WEBHOOK_SECRET=whsec_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_here

# Cloudflare Tunnel — separate tunnel from prod when staging gets a host.
CLOUDFLARE_TUNNEL_TOKEN=put-your-tunnel-token-here

# Support inbox (shared with prod is fine pre-tracción).
SUPPORT_EMAIL=soporte@raizdirecta.es
