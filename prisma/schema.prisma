generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN_SUPPORT
  ADMIN_CATALOG
  ADMIN_FINANCE
  ADMIN_OPS
  SUPERADMIN
}

enum VendorStatus {
  APPLYING
  PENDING_DOCS
  ACTIVE
  REJECTED
  SUSPENDED_TEMP
  SUSPENDED_PERM
}

// Public-facing producer type shown as a badge on vendor cards and the
// vendor detail page. Closed enum: adding a value requires a migration,
// which keeps labels consistent across the marketplace. When null, we
// fall back to a regex heuristic over displayName + description (see
// src/domains/vendors/visuals.ts).
enum VendorCategory {
  BAKERY
  CHEESE
  WINERY
  ORCHARD
  OLIVE_OIL
  FARM
  DRYLAND
  LOCAL_PRODUCER
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  REJECTED
  SUSPENDED
}

enum OrderStatus {
  PLACED
  PAYMENT_CONFIRMED
  PROCESSING
  PARTIALLY_SHIPPED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum FulfillmentStatus {
  PENDING
  CONFIRMED
  PREPARING
  LABEL_REQUESTED
  LABEL_FAILED
  READY
  SHIPPED
  DELIVERED
  INCIDENT
  CANCELLED
}

enum ShippingProviderCode {
  SENDCLOUD
}

enum ShipmentStatus {
  DRAFT
  LABEL_REQUESTED
  LABEL_CREATED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  EXCEPTION
  CANCELLED
  FAILED
}

enum ShipmentEventSource {
  SYSTEM
  PROVIDER_WEBHOOK
  MANUAL_ADMIN
  MANUAL_VENDOR
}

enum IncidentStatus {
  OPEN
  AWAITING_VENDOR
  AWAITING_CUSTOMER
  AWAITING_ADMIN
  RESOLVED
  CLOSED
}

enum IncidentType {
  ITEM_NOT_RECEIVED
  ITEM_DAMAGED
  WRONG_ITEM
  MISSING_ITEMS
  QUALITY_ISSUE
  OTHER
}

enum IncidentResolution {
  REFUND_FULL
  REFUND_PARTIAL
  REPLACEMENT
  STORE_CREDIT
  REJECTED
}

enum SettlementStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
}

enum CommissionType {
  PERCENTAGE
  FIXED
  TIERED
}

// #966 — who absorbs a refund: the platform itself (PLATFORM, e.g.
// goodwill / fraud charge-off) or the vendor (VENDOR, deducted from
// their next settlement). Used by `Refund.fundedBy` (NOT NULL) and
// `Incident.fundedBy` (nullable while the incident is OPEN, set on
// resolve). Replaces the prior `String` columns whose values were
// already constrained to these two literals at the Zod / route layer.
enum FundedBy {
  PLATFORM
  VENDOR
}

enum PromotionKind {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum PromotionScope {
  PRODUCT
  VENDOR
  CATEGORY
}

enum SubscriptionCadence {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELED
  PAST_DUE
}

// ─── Identity & Auth ──────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  emailVerified        DateTime?
  passwordHash         String?
  firstName            String
  lastName             String
  image                String?
  role                 UserRole  @default(CUSTOMER)
  isActive             Boolean   @default(true)
  deletedAt            DateTime?
  consentAcceptedAt    DateTime?
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  // #1142: bump on any event that must invalidate every active JWT for
  // this user — anonimization (GDPR Article 17), administrative
  // suspension, hard role change. The JWT callback in src/lib/auth.ts
  // stamps this onto the token at login and re-checks it on each
  // refresh tick; a stale token is rejected (no role / no id) so the
  // proxy redirects to /login. Distinct from `isActive` because some
  // intentional flows (vendor demotion, soft-suspend) want immediate
  // session kill without flipping the boolean.
  tokenVersion         Int       @default(0)
  // #1276: per-account login lockout. Counter is bumped atomically
  // on each failed credentials login and cleared on success. After
  // CREDENTIAL_LOCKOUT_THRESHOLD consecutive failures we set
  // `lockoutUntil` to a backoff-window in the future; logins inside
  // that window fail without checking the password. Combines with the
  // existing rate-limit (`login-identity` 10/15min) to bound a
  // distributed brute-force that rotates IPs.
  failedLoginAttempts  Int       @default(0)
  lockoutUntil         DateTime?
  // Phase 4b-β: created lazily on the first subscription checkout so we
  // can attach the same Stripe Customer to every future Checkout Session
  // and every renewal invoice.
  stripeCustomerId     String?   @unique
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  // #1359 — second source of actor traceability, independent of
  // `AuditLog`. Stored as plain string (not FK) so sentinel values
  // like 'system' / 'stripe-webhook' fit, and so a later GDPR
  // anonimization of the actor doesn't cascade into this row.
  createdById          String?
  updatedById          String?

  accounts                Account[]
  sessions                Session[]
  vendor                  Vendor?
  orders                  Order[]
  cart                    Cart?
  cart_items              CartItem[]
  addresses               Address[]
  incidents               Incident[]
  reviews                 Review[]
  reviewReports           ReviewReport[]
  favorites               Favorite[]
  subscriptions           Subscription[]
  pushSubscriptions       PushSubscription[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  twoFactor               UserTwoFactor?
  telegramLink            TelegramLink?
  telegramLinkTokens      TelegramLinkToken[]
  notificationPreferences NotificationPreference[]
  notificationDeliveries  NotificationDelivery[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Catalog ──────────────────────────────────────────────────────────────────

model Vendor {
  id                       String          @id @default(cuid())
  userId                   String          @unique
  slug                     String          @unique
  displayName              String
  description              String?         @db.Text
  logo                     String?
  logoAlt                  String?
  coverImage               String?
  coverImageAlt            String?
  location                 String?
  category                 VendorCategory?
  status                   VendorStatus    @default(APPLYING)
  // CHECK("commissionRate" >= 0 AND "commissionRate" <= 1) lives in the
  // 20260504180000 migration (#967). Prisma DSL has no native CHECK, so
  // the constraint is declared in SQL and enforced by Postgres on every
  // write — code-side validation is belt-and-braces.
  commissionRate           Decimal         @default(0.12) @db.Decimal(5, 4)
  avgRating                Decimal?        @db.Decimal(3, 2)
  totalReviews             Int             @default(0)
  orderCutoffTime          String?
  preparationDays          Int?            @default(2)
  // #1347 — at-rest crypto migration (epic #1346 PII pre-launch).
  // `iban` + `bankAccountName` stay as transient plaintext columns
  // until the backfill in `scripts/migrate-vendor-iban-encrypt.ts`
  // runs and a follow-up migration drops them. New writes go to the
  // *Encrypted columns; reads prefer encrypted with fallback to plain
  // during the transition. `ibanLast4` is intentionally unencrypted
  // (4 digits is not regulated PII on its own) so list pages can
  // render `**** 1234` without per-row crypto.
  iban                     String?
  ibanEncrypted            String?
  ibanLast4                String?
  bankAccountName          String?
  bankAccountNameEncrypted String?
  stripeAccountId          String?         @unique
  stripeOnboarded          Boolean         @default(false)

  // Phase 4 PR-E — ghost-vendor claim. Populated only when this
  // Vendor was created by Telegram ingestion (owned by a ghost
  // User). A real producer enters this code to take ownership;
  // once claimed, both columns are cleared and the Vendor looks
  // like any other self-serve vendor. Null for all vendors that
  // were created through `applyAsVendor`.
  claimCode          String?   @unique
  claimCodeExpiresAt DateTime?

  // #1277: per-vendor blob-storage budget. `storageBytesUsed` is
  // incremented on each successful upload through `/api/upload`;
  // `storageQuotaBytes` is the hard cap (default 500 MB). Admins can
  // bump the quota for high-volume producers without code changes.
  // Decrement is best-effort via the orphan-blob sweep — short-term
  // drift is acceptable, the UX is "contact admin to clean up".
  storageBytesUsed  BigInt @default(0)
  storageQuotaBytes BigInt @default(524288000)
  // #1279: per-vendor cap on simultaneously-active products. Prevents
  // a single compromised account from spamming the catalog. Default
  // is generous for an artisan producer; admins can bump per-vendor.
  maxProductsActive Int    @default(50)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // #1359 — see User/Order/Product for the contract.
  createdById String?
  updatedById String?

  user              User                @relation(fields: [userId], references: [id])
  products          Product[]
  fulfillments      VendorFulfillment[]
  settlements       Settlement[]
  reviews           Review[]
  addresses         VendorAddress[]
  promotions        Promotion[]
  subscriptionPlans SubscriptionPlan[]

  preferredShippingProvider ShippingProviderCode?

  @@index([status])
  @@index([slug])
}

model VendorAddress {
  id          String   @id @default(cuid())
  vendorId    String
  label       String?
  contactName String
  phone       String
  line1       String
  line2       String?
  city        String
  province    String
  postalCode  String
  countryCode String   @default("ES")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor       Vendor              @relation(fields: [vendorId], references: [id])
  fulfillments VendorFulfillment[]

  @@index([vendorId, isDefault])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  image       String?
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent     Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[]  @relation("CategoryTree")
  products   Product[]
  promotions Promotion[]

  @@index([slug])
  @@index([parentId])
}

model Product {
  id             String        @id @default(cuid())
  vendorId       String
  categoryId     String?
  name           String
  slug           String        @unique
  description    String?       @db.Text
  images         String[]
  imageAlts      String[]      @default([])
  status         ProductStatus @default(DRAFT)
  basePrice      Decimal       @db.Decimal(10, 2)
  compareAtPrice Decimal?      @db.Decimal(10, 2)
  taxRate        Decimal       @default(0.10) @db.Decimal(4, 3)
  unit           String        @default("kg")
  // Stock base solo se usa como fuente de verdad cuando el producto no define variantes activas.
  stock          Int           @default(0)
  trackStock     Boolean       @default(true)
  minOrderQty    Int           @default(1)
  weightGrams    Int?
  certifications String[]
  originRegion   String?
  tags           String[]
  expiresAt      DateTime?
  rejectionNote  String?
  archivedAt     DateTime?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  // #1359 — see User/Order/Vendor for the contract.
  createdById    String?
  updatedById    String?

  // Phase 4 — ingestion provenance. Set when this Product was created
  // by publishing an approved IngestionProductDraft. The UNIQUE
  // constraint on `sourceIngestionDraftId` is the sole mechanism that
  // prevents the "approve the same draft twice" race from inserting
  // duplicate products. `sourceTelegramMessageId` is kept as a
  // convenience for cross-references from Product back to the raw
  // Telegram message; it is a secondary handle and NOT unique (a
  // single message can theoretically yield several product drafts
  // when the extractor detects multiple products in one post).
  sourceIngestionDraftId  String? @unique
  sourceTelegramMessageId String?

  vendor            Vendor             @relation(fields: [vendorId], references: [id])
  category          Category?          @relation(fields: [categoryId], references: [id])
  variants          ProductVariant[]
  orderLines        OrderLine[]
  cartItems         CartItem[]
  reviews           Review[]
  favorites         Favorite[]
  promotions        Promotion[]
  // Multi-cadence (phase 4b-β follow-up): a product can now have more
  // than one active SubscriptionPlan, one per cadence. The unique
  // constraint is on (productId, cadence) — see model SubscriptionPlan.
  subscriptionPlans SubscriptionPlan[]

  @@index([status, categoryId])
  @@index([vendorId, status])
  @@index([expiresAt])
  @@index([slug])
  // Cursor pagination on /productos orders by [createdAt desc, id desc]
  // filtered by status. Composite index keeps page N constant-time
  // regardless of N. See #89.
  @@index([status, createdAt(sort: Desc), id(sort: Desc)])
  @@index([sourceTelegramMessageId])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  sku           String   @unique
  name          String
  priceModifier Decimal  @default(0) @db.Decimal(10, 2)
  // Si hay variantes activas y el producto trackea stock, este stock manda sobre Product.stock.
  stock         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  @@index([productId])
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  userId    String
  productId String
  variantId String?
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@index([userId, createdAt])
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Address {
  id         String   @id @default(cuid())
  userId     String
  label      String?
  firstName  String
  lastName   String
  line1      String
  line2      String?
  city       String
  province   String
  postalCode String
  country    String   @default("ES")
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]
  subscriptions Subscription[]

  @@index([userId])
}

model Order {
  id                      String        @id @default(cuid())
  orderNumber             String        @unique
  // Server-issued idempotency key (#410). Populated from the checkout
  // page render; `createOrder` rejects a duplicate by returning the
  // existing Order's id with `replayed: true`. Nullable for historical
  // rows created before the column existed.
  checkoutAttemptId       String?       @unique
  customerId              String
  addressId               String?
  shippingAddressSnapshot Json?
  status                  OrderStatus   @default(PLACED)
  paymentStatus           PaymentStatus @default(PENDING)
  subtotal                Decimal       @db.Decimal(10, 2)
  discountTotal           Decimal       @default(0) @db.Decimal(10, 2)
  shippingCost            Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount               Decimal       @db.Decimal(10, 2)
  grandTotal              Decimal       @db.Decimal(10, 2)
  notes                   String?
  placedAt                DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  // #1359 — see User/Vendor/Product for the contract.
  createdById             String?
  updatedById             String?

  // GDPR (#961): Order rows must be retained 5 years for tax compliance
  // — the account-erase flow at /api/account/delete anonimizes the User
  // without deleting the row. Restrict makes that contract explicit at
  // the schema level so a future Prisma migration cannot silently turn
  // this into a Cascade.
  customer     User                @relation(fields: [customerId], references: [id], onDelete: Restrict)
  address      Address?            @relation(fields: [addressId], references: [id])
  lines        OrderLine[]
  payments     Payment[]
  fulfillments VendorFulfillment[]
  incidents    Incident[]
  events       OrderEvent[]
  reviews      Review[]

  @@index([customerId, status])
  @@index([customerId, placedAt(sort: Desc)])
  @@index([status, placedAt(sort: Desc)])
  @@index([orderNumber])
}

model OrderLine {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  vendorId        String
  variantId       String?
  quantity        Int
  unitPrice       Decimal  @db.Decimal(10, 2)
  taxRate         Decimal  @db.Decimal(4, 3)
  productSnapshot Json
  createdAt       DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([vendorId])
  @@index([vendorId, createdAt])
}

model Review {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  vendorId   String
  customerId String
  rating     Int
  body       String?  @db.Text
  createdAt  DateTime @default(now())

  vendorResponse   String?   @db.Text
  vendorResponseAt DateTime?

  order    Order          @relation(fields: [orderId], references: [id])
  product  Product        @relation(fields: [productId], references: [id])
  vendor   Vendor         @relation(fields: [vendorId], references: [id])
  // GDPR (#961): Reviews are anonimized, not deleted, when the user
  // erases their account — the rating stays on the product but the
  // body and authorship are scrubbed. Restrict makes hard-deletion
  // explicitly forbidden at schema level.
  customer User           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  reports  ReviewReport[]

  @@unique([orderId, productId])
  @@index([productId])
  @@index([productId, createdAt])
  @@index([vendorId])
  @@index([vendorId, createdAt])
  @@index([customerId])
}

enum ReviewReportReason {
  SPAM
  OFFENSIVE
  OFF_TOPIC
  FAKE
  OTHER
}

enum ReviewReportTarget {
  REVIEW_BODY
  VENDOR_RESPONSE
}

model ReviewReport {
  id         String             @id @default(cuid())
  reviewId   String
  reporterId String
  target     ReviewReportTarget @default(REVIEW_BODY)
  reason     ReviewReportReason
  detail     String?            @db.Text
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime           @default(now())

  review   Review @relation(fields: [reviewId], references: [id])
  reporter User   @relation(fields: [reporterId], references: [id])

  // One report per (reviewId, reporterId, target) — prevents a buyer
  // from spamming the moderation queue by tapping flag twice.
  @@unique([reviewId, reporterId, target])
  @@index([resolvedAt])
  @@index([reviewId])
}

model VendorFulfillment {
  id             String            @id @default(cuid())
  orderId        String
  vendorId       String
  status         FulfillmentStatus @default(PENDING)
  trackingNumber String?
  carrier        String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  vendorAddressId String?

  // Phase 2 of the promotions RFC: one promotion per vendor fulfillment,
  // locked at order time. Free shipping promotions zero the vendor's share
  // of the shipping line via Order.shippingCost recalculation, not here.
  promotionId    String?
  discountAmount Decimal @default(0) @db.Decimal(10, 2)

  order         Order          @relation(fields: [orderId], references: [id])
  vendor        Vendor         @relation(fields: [vendorId], references: [id])
  vendorAddress VendorAddress? @relation(fields: [vendorAddressId], references: [id])
  shipment      Shipment?
  promotion     Promotion?     @relation(fields: [promotionId], references: [id])

  @@index([orderId])
  @@index([vendorId, status])
  @@index([vendorId, createdAt])
  @@index([promotionId])
}

model Shipment {
  id            String               @id @default(cuid())
  fulfillmentId String               @unique
  providerCode  ShippingProviderCode
  providerRef   String?
  status        ShipmentStatus       @default(DRAFT)

  fromAddressSnapshot Json
  toAddressSnapshot   Json

  weightGrams Int
  parcelCount Int @default(1)

  carrierName    String?
  trackingNumber String?
  trackingUrl    String?
  labelUrl       String?
  labelFormat    String?
  labelPrintedAt DateTime?

  labelRequestedAt DateTime?
  labelCreatedAt   DateTime?
  handedOverAt     DateTime?
  deliveredAt      DateTime?
  cancelledAt      DateTime?
  failedAt         DateTime?
  lastError        String?

  idempotencyKey String @unique

  providerMeta Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fulfillment VendorFulfillment @relation(fields: [fulfillmentId], references: [id])
  events      ShipmentEvent[]

  @@index([status])
  @@index([providerCode, providerRef])
  @@index([trackingNumber])
}

model ShipmentEvent {
  id         String              @id @default(cuid())
  shipmentId String
  source     ShipmentEventSource
  type       String
  status     ShipmentStatus?
  message    String?
  payload    Json?
  occurredAt DateTime
  createdAt  DateTime            @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id])

  @@index([shipmentId, occurredAt])
  @@index([type])
}

model OrderEvent {
  id            String   @id @default(cuid())
  orderId       String
  actorId       String?
  type          String
  // Payload schema version (#965). Bump in code when the shape of
  // `payload` changes for a given `type`, so historical reports can
  // parse old rows with the matching reader. See
  // src/domains/orders/order-events.ts for the typed enum + readers.
  schemaVersion Int      @default(1)
  payload       Json?
  createdAt     DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

/// First-class delivery bookkeeping for webhook events. Lets the
/// stripe webhook handler dedupe by `(provider, eventId)` via a real
/// unique constraint instead of a JSON-path lookup against
/// `OrderEvent.payload`. Created (insert + unique violation = duplicate)
/// in the route handler before any business state mutation; updated to
/// `processed` / `failed` after the handler returns. Replaces the
/// dedupe responsibility of `OrderEvent` while leaving its
/// business-event responsibility intact.
///
/// `payloadHash` is sha256(raw body), useful for forensic comparisons
/// without storing the full payload (which can carry PII or card
/// metadata depending on the provider).
model WebhookDelivery {
  id           String    @id @default(cuid())
  provider     String    @default("stripe")
  eventId      String
  eventType    String
  providerRef  String?
  status       String    @default("received")
  errorMessage String?
  payloadHash  String?
  receivedAt   DateTime  @default(now())
  processedAt  DateTime?

  @@unique([provider, eventId])
  @@index([provider, eventType, receivedAt])
  @@index([status, receivedAt])
}

/// Dead-letter queue for webhook events that could not be reconciled to an
/// existing order/payment (e.g. Stripe sent a payment_intent.succeeded for a
/// providerRef we have no Payment row for). An operator can query the
/// unresolved rows and replay them from the Stripe dashboard once the
/// underlying issue is fixed.
model WebhookDeadLetter {
  id          String    @id @default(cuid())
  provider    String    @default("stripe")
  eventId     String?
  eventType   String
  providerRef String?
  reason      String
  payload     Json?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime  @default(now())

  @@index([resolvedAt])
  @@index([provider, eventType])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  provider          String        @default("stripe")
  providerRef       String?       @unique
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("EUR")
  status            PaymentStatus @default(PENDING)
  metadata          Json?
  // Watermark for out-of-order webhook delivery (#959). Mirrors the
  // pattern on Subscription.lastStripeEventAt: the handler drops any
  // event whose `event.created` is older than this value, so a late
  // payment_intent.succeeded arriving after charge.refunded cannot
  // resurrect a refunded order. Updated only on successful state
  // transition; concurrent handlers for the same eventId are still
  // deduped upstream by WebhookDelivery(provider, eventId).
  lastStripeEventAt DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order   Order    @relation(fields: [orderId], references: [id])
  refunds Refund[]

  @@index([orderId])
  @@index([orderId, status])
  @@index([providerRef])
  @@index([lastStripeEventAt])
}

model Refund {
  id          String   @id @default(cuid())
  paymentId   String
  amount      Decimal  @db.Decimal(10, 2)
  reason      String
  fundedBy    FundedBy
  providerRef String?  @unique
  createdAt   DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
}

// ─── Incidents ────────────────────────────────────────────────────────────────

model Incident {
  id           String              @id @default(cuid())
  orderId      String
  customerId   String
  type         IncidentType
  status       IncidentStatus      @default(OPEN)
  description  String              @db.Text
  attachments  String[]            @default([])
  resolution   IncidentResolution?
  fundedBy     FundedBy?
  refundAmount Decimal?            @db.Decimal(10, 2)
  internalNote String?             @db.Text
  slaDeadline  DateTime
  resolvedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  order    Order             @relation(fields: [orderId], references: [id])
  // GDPR (#961): Incident records are part of the order audit trail and
  // are retained alongside Order rows for tax/dispute compliance. The
  // account-erase flow does not touch them. Restrict prevents a future
  // hard-delete from cascade-wiping support history.
  customer User              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  messages IncidentMessage[]

  @@index([status, slaDeadline])
  @@index([customerId])
  @@index([customerId, status])
  @@index([createdAt])
}

model IncidentMessage {
  id          String   @id @default(cuid())
  incidentId  String
  authorId    String
  authorRole  String
  body        String   @db.Text
  attachments String[]
  createdAt   DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id])

  @@index([incidentId])
  @@index([incidentId, createdAt])
}

// ─── Finance ──────────────────────────────────────────────────────────────────

model CommissionRule {
  id         String         @id @default(cuid())
  vendorId   String?
  categoryId String?
  type       CommissionType @default(PERCENTAGE)
  // CHECK gated on type = 'PERCENTAGE': rate ∈ [0, 1]. FIXED rules use
  // rate as an absolute EUR amount (e.g. 1.25 €) and are out of scope.
  // Constraint lives in the 20260504180000 migration (#967).
  rate       Decimal        @db.Decimal(5, 4)
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([vendorId])
}

model Settlement {
  id          String           @id @default(cuid())
  vendorId    String
  periodFrom  DateTime
  periodTo    DateTime
  grossSales  Decimal          @db.Decimal(10, 2)
  commissions Decimal          @db.Decimal(10, 2)
  refunds     Decimal          @db.Decimal(10, 2)
  adjustments Decimal          @default(0) @db.Decimal(10, 2)
  netPayable  Decimal          @db.Decimal(10, 2)
  status      SettlementStatus @default(DRAFT)
  paidAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId, status])
  @@index([periodFrom, periodTo])
}

// ─── Promotions ───────────────────────────────────────────────────────────────
// Phase 1 of the promotions RFC (docs/rfcs/0001-promotions-and-subscriptions.md).
// Vendors can draft campaigns, but they are dormant until phase 2 wires them
// into the checkout flow. No Stripe Coupon sync yet.

model Promotion {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  name  String
  code  String? // vendor-defined coupon code, uppercased
  kind  PromotionKind
  // For PERCENTAGE this is 0..100. For FIXED_AMOUNT it is an absolute EUR
  // amount. For FREE_SHIPPING it is ignored (stored as 0).
  value Decimal       @db.Decimal(10, 2)

  scope      PromotionScope
  productId  String?
  product    Product?       @relation(fields: [productId], references: [id])
  categoryId String?
  category   Category?      @relation(fields: [categoryId], references: [id])

  minSubtotal     Decimal? @db.Decimal(10, 2)
  maxRedemptions  Int?
  perUserLimit    Int?     @default(1)
  redemptionCount Int      @default(0)

  startsAt   DateTime
  endsAt     DateTime
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fulfillments VendorFulfillment[]

  @@unique([vendorId, code])
  @@index([vendorId, archivedAt])
  @@index([vendorId, startsAt, endsAt])
}

// ─── Subscriptions ────────────────────────────────────────────────────────────
// Phase 3 of the promotions & subscriptions RFC. Vendors can now mark one
// product as a subscription "box" with a fixed cadence. The buyer-facing
// purchase flow (Stripe Subscriptions, skip, pause, cancel) lands in phase
// 4 — at which point this model will be joined by a `Subscription` model
// representing an actual buyer subscription instance.

model SubscriptionPlan {
  id        String  @id @default(cuid())
  vendorId  String
  vendor    Vendor  @relation(fields: [vendorId], references: [id])
  // Multi-cadence: a single product can have up to one plan per cadence
  // (e.g. weekly + biweekly + monthly). The unique constraint used to
  // be on productId alone, which forced a single subscription offer
  // per product. Phase 4b-β lifts that so buyers can pick the frequency
  // they want on the confirmation page — see @@unique at the bottom.
  productId String
  product   Product @relation(fields: [productId], references: [id])

  cadence         SubscriptionCadence
  // Prices and tax rates are snapshotted on the plan so a later product
  // edit does not retroactively change the amount charged on renewals.
  priceSnapshot   Decimal             @db.Decimal(10, 2)
  taxRateSnapshot Decimal             @db.Decimal(4, 3)
  // 0 = Sunday … 6 = Saturday. The vendor's skip/cancel deadline for the
  // next scheduled delivery. e.g. cutoff=5 (Friday) for a Monday drop.
  cutoffDayOfWeek Int

  // Reserved for phase 4b. Stripe Price id for the recurring charge.
  stripePriceId String?
  archivedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  // Vendor can publish at most one ACTIVE plan per (product, cadence).
  // A second plan with the same cadence on the same product would mean
  // two concurrent recurring offers that only differ by id — banned at
  // the DB level rather than trusting the app-layer check in
  // createSubscriptionPlan. Different cadences coexist fine:
  // (prod-cesta, WEEKLY) + (prod-cesta, BIWEEKLY) is valid.
  @@unique([productId, cadence])
  @@index([vendorId, archivedAt])
}

// Phase 4a of the promotions & subscriptions RFC. Buyer-facing instance of
// a SubscriptionPlan. Phase 4a only models the domain + vendor-only flow —
// Stripe Subscriptions, renewal webhooks and the public subscribe CTA
// land in phase 4b. Until the SUBSCRIPTIONS_BUYER_BETA env flag is set to
// 'true' the server action that creates new rows refuses to run, so no
// buyer can end up with a dangling "subscribed but never charged" record.
model Subscription {
  id                String           @id @default(cuid())
  buyerId           String
  buyer             User             @relation(fields: [buyerId], references: [id])
  planId            String
  plan              SubscriptionPlan @relation(fields: [planId], references: [id])
  shippingAddressId String
  shippingAddress   Address          @relation(fields: [shippingAddressId], references: [id])

  status            SubscriptionStatus @default(ACTIVE)
  // Computed from the plan cadence on every cycle transition. Renewals
  // (phase 4b) will read this to schedule the next charge.
  currentPeriodEnd  DateTime
  nextDeliveryAt    DateTime
  // Array of ISO-dates (YYYY-MM-DD) the buyer asked to skip. Stored as
  // JSON so we can also persist optional notes per skip in the future
  // without a migration.
  skippedDeliveries Json               @default("[]")

  // Reserved for phase 4b.
  stripeSubscriptionId String? @unique

  // Watermark for Stripe webhook ordering. Each accepted
  // customer.subscription.* / invoice.* event sets this to its
  // top-level event.created timestamp; subsequent events with an
  // older `created` are dropped as out-of-order to prevent state
  // regressions (e.g. a stale `updated(ACTIVE)` overwriting a
  // newer `deleted(CANCELED)`). Stripe does not guarantee delivery
  // order, so we cannot trust the arrival sequence.
  lastStripeEventAt DateTime?

  // When set, the subscription auto-resumes on this date. Null means
  // the pause is indefinite (the old behaviour). Populated by the
  // "pause with duration" dialog so the vendor doesn't lose recurring
  // revenue to forgotten pauses.
  pausedUntil DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  canceledAt DateTime?

  @@unique([buyerId, planId])
  @@index([buyerId, status])
  @@index([planId, status])
}

// ─── Logistics ────────────────────────────────────────────────────────────────

model ShippingZone {
  id        String   @id @default(cuid())
  name      String
  provinces String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  rates ShippingRate[]
}

model ShippingRate {
  id             String   @id @default(cuid())
  zoneId         String
  name           String
  minWeight      Decimal? @db.Decimal(8, 3)
  maxWeight      Decimal? @db.Decimal(8, 3)
  minOrderAmount Decimal? @db.Decimal(10, 2)
  price          Decimal  @db.Decimal(10, 2)
  freeAbove      Decimal? @db.Decimal(10, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  zone ShippingZone @relation(fields: [zoneId], references: [id])
}

// ─── System ───────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  actorId    String
  actorRole  String
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

model MarketplaceConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

// ─── Authentication Tokens ────────────────────────────────────────────────────

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// TOTP second factor for admin accounts. One-to-one with User; only
// admins are required to enroll (enforced by the login gate) but the
// model is role-agnostic so a future buyer-2FA opt-in needs no
// migration. `secretEncrypted` stores the base32 TOTP secret AES-256
// encrypted with a key derived from AUTH_SECRET so a DB/backup leak
// alone is not enough to bypass the second factor.
model UserTwoFactor {
  userId          String    @id
  secretEncrypted String    @db.Text
  enabledAt       DateTime?
  // Monotonically increasing step counter of the LAST accepted code.
  // Rejects replay of the same 30 s TOTP inside its window even if an
  // attacker grabs the code off a screenshot. Updated on every verify.
  lastUsedStep    BigInt?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Push Notifications ──────────────────────────────────────────────────────

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String   @db.Text
  auth       String   @db.Text
  userAgent  String?
  uaCategory String   @default("other")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Notifications (Telegram) ────────────────────────────────────────────────
// See docs/rfcs/0002-telegram-integration.md. All tables are additive; feature
// is dormant until TELEGRAM_BOT_TOKEN is set.

enum NotificationChannel {
  TELEGRAM
  WEB_PUSH
}

enum NotificationEventType {
  ORDER_CREATED
  ORDER_PENDING
  MESSAGE_RECEIVED
  ORDER_DELIVERED
  LABEL_FAILED
  INCIDENT_OPENED
  REVIEW_RECEIVED
  PAYOUT_PAID
  STOCK_LOW
  BUYER_ORDER_STATUS
  BUYER_FAVORITE_RESTOCK
  BUYER_FAVORITE_PRICE_DROP
  BUYER_VENDOR_APPLICATION_APPROVED
  BUYER_VENDOR_APPLICATION_REJECTED
}

enum NotificationDeliveryStatus {
  SENT
  FAILED
  SKIPPED
}

model TelegramLink {
  id         String    @id @default(cuid())
  userId     String    @unique
  chatId     String    @unique
  username   String?
  isActive   Boolean   @default(true)
  linkedAt   DateTime  @default(now())
  lastSeenAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isActive])
}

model TelegramLinkToken {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model NotificationPreference {
  id        String                @id @default(cuid())
  userId    String
  channel   NotificationChannel
  eventType NotificationEventType
  enabled   Boolean               @default(true)
  updatedAt DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel, eventType])
  @@index([userId])
}

model NotificationDelivery {
  id         String                     @id @default(cuid())
  userId     String
  channel    NotificationChannel
  eventType  NotificationEventType
  status     NotificationDeliveryStatus
  error      String?                    @db.Text
  payloadRef String?
  createdAt  DateTime                   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model TelegramActionLog {
  id        String   @id @default(cuid())
  userId    String?
  chatId    String
  action    String
  payload   Json
  success   Boolean
  error     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([chatId, createdAt])
}

// ─── Telegram ingestion (PHASE 1 — raw data only) ────────────────────────────
//
// Observer-side read of public Telegram groups via a MTProto sidecar
// (Telethon). Completely separate from TelegramLink / TelegramActionLog,
// which are for the USER-facing notification bot. Naming is explicit
// (TelegramIngestion*) to avoid any confusion between the two concerns.
//
// These tables are the source of truth for raw messages; nothing here
// feeds Product / Vendor / ProductImage in Phase 1. Processing, drafts,
// and publishing land in later phases behind the same kill switch.

enum TelegramIngestionChatKind {
  GROUP
  SUPERGROUP
  CHANNEL
}

enum TelegramIngestionConnectionStatus {
  PENDING
  ACTIVE
  REVOKED
}

enum TelegramIngestionMediaKind {
  PHOTO
  VIDEO
  DOCUMENT
  OTHER
}

enum TelegramIngestionMediaStatus {
  PENDING
  DOWNLOADED
  SKIPPED_OVERSIZE
  SOURCE_GONE
  FAILED
}

enum TelegramIngestionSyncStatus {
  RUNNING
  OK
  FAILED
  CANCELLED
}

enum IngestionJobStatus {
  QUEUED
  RUNNING
  OK
  FAILED
  DEAD
}

model TelegramIngestionConnection {
  id              String                            @id @default(cuid())
  label           String
  // One-way hash of the phone number that owns the Telethon session.
  // The actual phone number and session data live ONLY inside the
  // sidecar's encrypted volume — never in this DB.
  phoneNumberHash String
  // Opaque pointer the sidecar uses to look up its local session.
  sessionRef      String                            @unique
  status          TelegramIngestionConnectionStatus @default(PENDING)
  createdByUserId String
  createdAt       DateTime                          @default(now())
  updatedAt       DateTime                          @updatedAt

  chats TelegramIngestionChat[]

  @@index([status])
  @@index([createdByUserId])
}

model TelegramIngestionChat {
  id             String                    @id @default(cuid())
  connectionId   String
  // Telegram chat IDs exceed 32-bit; BigInt is required.
  tgChatId       BigInt
  title          String
  kind           TelegramIngestionChatKind
  // Incremental sync cursor. Only advanced after a batch lands in DB.
  lastMessageId  BigInt?
  isEnabled      Boolean                   @default(false)
  disabledReason String?                   @db.Text
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  connection TelegramIngestionConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  messages   TelegramIngestionMessage[]
  syncRuns   TelegramIngestionSyncRun[]

  @@unique([connectionId, tgChatId])
  @@index([isEnabled])
}

model TelegramIngestionMessage {
  id          String   @id @default(cuid())
  chatId      String
  tgMessageId BigInt
  tgAuthorId  BigInt?
  text        String?  @db.Text
  // Raw Telethon payload. Retained until the raw-payload sweep
  // nulls it out in place; the message row itself stays forever.
  rawJson     Json?
  postedAt    DateTime
  fetchedAt   DateTime @default(now())
  // Phase-1-ready hook for the right-to-erasure / tombstone flow.
  tombstoned  Boolean  @default(false)
  // Forum-topic metadata. Telegram supergroups can be partitioned
  // into topics (the megaphone-style channels at the left of the
  // app); messages outside any topic — i.e. the main feed — leave
  // both fields null. We capture the id (so stats can partition
  // without re-parsing rawJson) and a snapshot of the title at
  // ingestion time (cheap denormalisation; can be re-resolved from
  // the chat's topic list if it ever drifts).
  topicId     BigInt?
  topicTitle  String?

  chat                       TelegramIngestionChat           @relation(fields: [chatId], references: [id], onDelete: Cascade)
  media                      TelegramIngestionMessageMedia[]
  ingestionExtractionResults IngestionExtractionResult[]
  ingestionProductDrafts     IngestionProductDraft[]

  @@unique([chatId, tgMessageId])
  @@index([chatId, postedAt(sort: Desc)])
  @@index([chatId, topicId])
  @@index([tgAuthorId])
}

model TelegramIngestionMessageMedia {
  id           String                       @id @default(cuid())
  messageId    String
  // Telegram's stable unique id lets us dedupe across messages that
  // forward the same media. One download → one blob → many references.
  fileUniqueId String                       @unique
  kind         TelegramIngestionMediaKind
  status       TelegramIngestionMediaStatus @default(PENDING)
  blobKey      String?
  sizeBytes    Int?
  mimeType     String?
  downloadedAt DateTime?
  lastErrorMsg String?                      @db.Text
  createdAt    DateTime                     @default(now())

  message TelegramIngestionMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([status])
}

model TelegramIngestionSyncRun {
  id              String                      @id @default(cuid())
  chatId          String
  status          TelegramIngestionSyncStatus @default(RUNNING)
  startedAt       DateTime                    @default(now())
  finishedAt      DateTime?
  fromMessageId   BigInt?
  toMessageId     BigInt?
  messagesFetched Int                         @default(0)
  mediaFetched    Int                         @default(0)
  errorMessage    String?                     @db.Text
  // Correlation id threaded to every log line emitted during the run.
  correlationId   String

  chat TelegramIngestionChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, startedAt(sort: Desc)])
  @@index([status])
}

// Admin-visible mirror of pg-boss job outcomes. pg-boss keeps its own
// `pgboss.*` schema for internal state; this table exists so the admin
// panel + operators can browse ingestion job history using the same
// Prisma client as the rest of the app.
model IngestionJob {
  id           String             @id @default(cuid())
  kind         String
  status       IngestionJobStatus @default(QUEUED)
  // Opaque payload pointer (e.g. chatId, messageMediaId). Kept small
  // on purpose; the full payload stays in pg-boss.
  payloadRef   String
  attempts     Int                @default(0)
  lastErrorMsg String?            @db.Text
  lastErrorAt  DateTime?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([kind, status])
  @@index([status, createdAt])
}

// ─── Telegram ingestion processing (PHASE 2 — deterministic drafts) ──────────
//
// Deterministic intermediate layer between raw messages and any future
// catalog publishing. Rules-only in Phase 2; LLM is deferred to Phase
// 2.5 behind a separate flag. Source of truth remains
// `TelegramIngestionMessage`; drafts never mutate raw and always carry
// provenance via `sourceMessageId`.
//
// Locked invariants (see #679 comment 4281108530):
//   - idempotency key on drafts: (sourceMessageId, extractorVersion, productOrdinal)
//   - ExtractionResult unique on (messageId, extractorVersion)
//   - every extraction carries `inputSnapshot` so rule changes don't
//     invalidate historical results
//   - confidence range [0,1] + fixed bands HIGH (≥0.8) / MEDIUM / LOW
//   - non-destructive dedupe via canonicalDraftId / duplicateOf
//   - ReviewQueueItem states limited to ENQUEUED | AUTO_RESOLVED

enum IngestionExtractorEngine {
  RULES
  // LLM reserved for Phase 2.5 — deliberate, not implemented in Phase 2.
  LLM
}

enum IngestionConfidenceBand {
  LOW
  MEDIUM
  HIGH
}

enum IngestionDraftStatus {
  PENDING
  APPROVED
  REJECTED
  TOMBSTONED
}

enum IngestionDraftKind {
  PRODUCT_DRAFT
  VENDOR_DRAFT
  DEDUPE_CANDIDATE
  // Added in rules-1.1.0. Enqueued when the classifier says PRODUCT
  // (or PRODUCT_NO_PRICE) but the extractor could not materialise a
  // draft — either because there was no price signal or the fields
  // looked like a promo. `targetId` points at the
  // IngestionExtractionResult.id instead of a draft id.
  UNEXTRACTABLE_PRODUCT
}

enum IngestionReviewState {
  ENQUEUED
  AUTO_RESOLVED
}

enum IngestionDedupeKind {
  STRONG
  HEURISTIC
  SIMILARITY
}

enum IngestionDedupeRisk {
  LOW
  MEDIUM
  HIGH
}

enum IngestionMessageClass {
  PRODUCT
  // Added in rules-1.1.0. Producer-flavoured post that does NOT
  // contain a usable price token (very common in real chats where
  // price is moved to DM). The extractor runs but does not produce
  // drafts; the drafts builder enqueues an UNEXTRACTABLE_PRODUCT
  // review queue item so the message stays visible to operators.
  PRODUCT_NO_PRICE
  CONVERSATION
  SPAM
  OTHER
}

model IngestionExtractionResult {
  id                String                   @id @default(cuid())
  messageId         String
  engine            IngestionExtractorEngine @default(RULES)
  extractorVersion  String
  schemaVersion     Int                      @default(1)
  // Raw-message snapshot at extraction time so historical results
  // stay self-contained when rules change. Never mutated.
  inputSnapshot     Json
  // Extractor output, pinned by a Zod freeze test.
  payload           Json
  // Overall confidence in [0,1]. Decimal(3,2) to keep shape stable.
  confidenceOverall Decimal                  @db.Decimal(3, 2)
  confidenceBand    IngestionConfidenceBand
  confidenceByField Json
  classification    IngestionMessageClass?
  // Cost fields reserved for Phase 2.5 (LLM); always NULL for RULES.
  costTokensIn      Int?
  costTokensOut     Int?
  costUsd           Decimal?                 @db.Decimal(10, 4)
  correlationId     String
  createdAt         DateTime                 @default(now())

  message       TelegramIngestionMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  productDrafts IngestionProductDraft[]

  // rules-1.2.0: unextractable-dedupe candidates reference this
  // row via two optional relations (left vs right side of the pair).
  unextractableLefts  IngestionUnextractableDedupeCandidate[] @relation("UnextractableLeft")
  unextractableRights IngestionUnextractableDedupeCandidate[] @relation("UnextractableRight")

  // Re-running the same extractor version on the same message MUST
  // be a no-op. Bumping the version creates a new revision row.
  @@unique([messageId, extractorVersion])
  @@index([messageId, createdAt(sort: Desc)])
  @@index([engine, extractorVersion])
}

model IngestionVendorDraft {
  id                     String                  @id @default(cuid())
  // Hash of phone, username, bot id — the stable identifier we can
  // match across messages. Null when the extractor could not infer a
  // stable identity; such drafts NEVER auto-merge.
  externalId             String?
  displayName            String
  // Provenance: which messages contributed to inferring this vendor.
  inferredFromMessageIds Json
  extractorVersion       String
  confidenceOverall      Decimal                 @db.Decimal(3, 2)
  confidenceBand         IngestionConfidenceBand
  status                 IngestionDraftStatus    @default(PENDING)
  // Non-destructive dedupe pointers. When null, this row IS canonical.
  canonicalDraftId       String?
  duplicateOf            String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  canonical IngestionVendorDraft?  @relation("VendorDraftCanonical", fields: [canonicalDraftId], references: [id], onDelete: SetNull)
  merges    IngestionVendorDraft[] @relation("VendorDraftCanonical")

  productDrafts IngestionProductDraft[]

  @@unique([externalId, extractorVersion])
  @@index([status])
  @@index([canonicalDraftId])
}

model IngestionProductDraft {
  id                 String                  @id @default(cuid())
  sourceMessageId    String
  sourceExtractionId String
  extractorVersion   String
  // 0-based index into the extractor's product array for this message.
  productOrdinal     Int                     @default(0)
  vendorDraftId      String?
  status             IngestionDraftStatus    @default(PENDING)
  confidenceOverall  Decimal                 @db.Decimal(3, 2)
  confidenceBand     IngestionConfidenceBand
  // Structured fields produced by the extractor. `null` means the
  // field was not present or not inferred.
  productName        String?
  categorySlug       String?
  unit               String?
  weightGrams        Int?
  priceCents         Int?
  currencyCode       String?
  availability       String?
  rawFieldsSeen      Json
  // Non-destructive dedupe pointers. Canonical when null.
  canonicalDraftId   String?
  duplicateOf        String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  sourceMessage    TelegramIngestionMessage  @relation(fields: [sourceMessageId], references: [id], onDelete: Cascade)
  sourceExtraction IngestionExtractionResult @relation(fields: [sourceExtractionId], references: [id], onDelete: Cascade)
  vendorDraft      IngestionVendorDraft?     @relation(fields: [vendorDraftId], references: [id], onDelete: SetNull)
  canonical        IngestionProductDraft?    @relation("ProductDraftCanonical", fields: [canonicalDraftId], references: [id], onDelete: SetNull)
  merges           IngestionProductDraft[]   @relation("ProductDraftCanonical")

  // Idempotency key: re-running the same version on the same message
  // returns the existing row for every ordinal.
  @@unique([sourceMessageId, extractorVersion, productOrdinal], map: "IngestionProductDraft_source_ver_ordinal_key")
  @@index([status, createdAt(sort: Desc)])
  @@index([vendorDraftId])
  @@index([canonicalDraftId])
  @@index([confidenceBand])
}

model IngestionReviewQueueItem {
  id                 String               @id @default(cuid())
  kind               IngestionDraftKind
  targetId           String
  priority           Int                  @default(0)
  state              IngestionReviewState @default(ENQUEUED)
  // Populated only when state transitions to AUTO_RESOLVED (LOW-risk
  // dedupe auto-merge). Everything else stays ENQUEUED until Phase 3
  // introduces the manual-review state machine.
  autoResolvedReason String?
  autoResolvedAt     DateTime?
  createdAt          DateTime             @default(now())

  @@unique([kind, targetId])
  @@index([state, priority(sort: Desc), createdAt])
}

model IngestionDedupeCandidate {
  id            String              @id @default(cuid())
  leftDraftId   String
  rightDraftId  String
  kind          IngestionDedupeKind
  riskClass     IngestionDedupeRisk
  reasonJson    Json
  // True only for LOW-risk auto-applied merges. MEDIUM / HIGH always
  // remain false in Phase 2 (manual review is mandatory).
  autoApplied   Boolean             @default(false)
  autoAppliedAt DateTime?
  createdAt     DateTime            @default(now())

  @@unique([leftDraftId, rightDraftId, kind])
  @@index([riskClass, autoApplied])
  @@index([createdAt])
}

// Phase 2.x iter-2 / rules-1.2.0: dedupe candidates for
// `PRODUCT_NO_PRICE` extractions. Separate table from
// `IngestionDedupeCandidate` by design (user rejected polymorphic
// target columns) — a candidate here always links two
// `IngestionExtractionResult` rows, never drafts. Policy mirrors the
// product-draft dedupe: only STRONG → LOW → auto-merge, MEDIUM / HIGH
// require human review. The "merge" in this table is a pointer
// operation on the review queue (ENQUEUED → AUTO_RESOLVED), never a
// destructive write to the extraction rows.
model IngestionUnextractableDedupeCandidate {
  id                String              @id @default(cuid())
  leftExtractionId  String
  rightExtractionId String
  kind              IngestionDedupeKind
  riskClass         IngestionDedupeRisk
  reasonJson        Json
  autoApplied       Boolean             @default(false)
  autoAppliedAt     DateTime?
  createdAt         DateTime            @default(now())

  leftExtraction  IngestionExtractionResult @relation("UnextractableLeft", fields: [leftExtractionId], references: [id], onDelete: Cascade)
  rightExtraction IngestionExtractionResult @relation("UnextractableRight", fields: [rightExtractionId], references: [id], onDelete: Cascade)

  @@unique([leftExtractionId, rightExtractionId, kind], map: "IngUnxDedupe_left_right_kind_key")
  @@index([riskClass, autoApplied], map: "IngUnxDedupe_riskClass_autoApplied_idx")
  @@index([createdAt], map: "IngUnxDedupe_createdAt_idx")
}

// Generic idempotency keys for admin/vendor mutations (#788).
// Generalizes the `Order.checkoutAttemptId` pattern (see
// docs/checkout-dedupe.md) to any server action that needs to be
// safe against double-submit on degraded mobile networks.
//
// The (scope, token) UNIQUE is the dedupe pivot: scope isolates
// different mutation types (so a `product.create` token can never
// collide with a `promotion.update` token), and `userId` is enforced
// at the wrapper level for cross-tenant safety (see
// docs/authz-audit.md). Tokens auto-expire after 24h; a cleanup job
// reads `expiresAt` to GC.
model IdempotencyKey {
  id        String   @id @default(cuid())
  scope     String
  token     String
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([scope, token])
  @@index([userId])
  @@index([expiresAt])
}
