# ===========================
# DATABASE
# ===========================
# PostgreSQL connection string (created by docker-compose)
DATABASE_URL="postgresql://mp_user:mp_pass@localhost:5432/marketplace"

# ===========================
# AUTHENTICATION (NextAuth v5)
# ===========================
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-random-secret-here"
AUTH_URL="http://localhost:3000"

# ===========================
# PUBLIC APP
# ===========================
# Frontend URL (used by emails and redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================
# PAYMENTS
# ===========================
# Mode: "mock" (default, auto-confirms orders) or "stripe" (real Stripe)
PAYMENT_PROVIDER="mock"

# Only required when PAYMENT_PROVIDER="stripe"
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ===========================
# EMAILS (optional)
# ===========================
# Uses Resend API for transactional emails
# RESEND_API_KEY="re_..."

# ===========================
# NOTES
# ===========================
# For development: use .env.local (git-ignored)
# For testing: use .env.test
# Never commit real secrets!
