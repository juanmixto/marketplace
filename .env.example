# ===========================
# DATABASE
# ===========================
# PostgreSQL connection string (created by docker-compose)
DATABASE_URL="postgresql://mp_user:mp_pass@localhost:5432/marketplace"

# ===========================
# AUTHENTICATION (NextAuth v5)
# ===========================
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-random-secret-here"
AUTH_URL="http://localhost:3000"

# Google OAuth — provider is registered iff BOTH vars are set.
# Setup runbook: docs/auth/google-setup.md
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# ===========================
# PUBLIC APP
# ===========================
# Frontend URL (used by emails and redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: enables GA4 page/event tracking when configured
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Optional: enables PostHog product analytics when configured
# NEXT_PUBLIC_POSTHOG_KEY="phc_..."
# NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# ===========================
# ERROR TRACKING (Sentry) — optional
# ===========================
# When set, every unhandled server + client error is reported to Sentry
# with correlationId, userId (no email/PII), and the release SHA. The
# scrubber in src/lib/sentry/scrubber.ts strips emails/phones/tokens
# from every event before it leaves the process.
# Get a DSN from https://sentry.io/ (free plan works for MVP) or run
# self-hosted GlitchTip / Sentry.
# SENTRY_DSN="https://...@o0.ingest.sentry.io/0"
# NEXT_PUBLIC_SENTRY_DSN="https://...@o0.ingest.sentry.io/0"
# SENTRY_ENVIRONMENT="production"                    # defaults to NODE_ENV
# SENTRY_TRACES_SAMPLE_RATE="0.1"                    # 10% of traffic
# SENTRY_REPLAYS_SESSION_SAMPLE_RATE="0"             # browser Replay off by default
# SENTRY_REPLAYS_ONERROR_SAMPLE_RATE="0.5"           # record 50% of sessions that crash
# NEXT_PUBLIC_COMMIT_SHA="abc1234"                    # injected at build for release tagging

# ===========================
# PAYMENTS
# ===========================
# Mode: "mock" (default, auto-confirms orders) or "stripe" (real Stripe)
PAYMENT_PROVIDER="mock"

# Only required when PAYMENT_PROVIDER="stripe"
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ===========================
# BUILD IDENTITY (auto-detected from git, override only if needed)
# ===========================
# next.config.ts auto-stamps these from `git rev-parse` at build/dev time.
# Override when running outside a git checkout (e.g. Docker COPY-only),
# or to pin a specific value in CI:
# NEXT_PUBLIC_COMMIT_SHA="abc1234"
# NEXT_PUBLIC_GIT_BRANCH="main"
# NEXT_PUBLIC_BUILD_TIME="2026-04-19T00:00:00Z"
# Hide the floating build badge in production:
# NEXT_PUBLIC_HIDE_BUILD_BADGE="true"

# ===========================
# EMAILS (optional)
# ===========================
# Uses Resend API for transactional emails
# RESEND_API_KEY="re_..."
# Default sender and contact inbox for production use
# EMAIL_FROM="no-reply@your-domain.com"
# CONTACT_EMAIL="support@your-domain.com"

# ===========================
# SHIPPING
# ===========================
# Provider: "SENDCLOUD" (default, recommended) or "MOCK" (tests / local)
# SHIPPING_PROVIDER="SENDCLOUD"

# Only required when SHIPPING_PROVIDER="SENDCLOUD"
# Get these from https://panel.sendcloud.sc/ → Integrations → API
# SENDCLOUD_PUBLIC_KEY="..."
# SENDCLOUD_SECRET_KEY="..."
# SENDCLOUD_WEBHOOK_SECRET="..."
# SENDCLOUD_SENDER_ID="123"                       # numeric sender address id
# SENDCLOUD_BASE_URL="https://panel.sendcloud.sc/api/v2"  # optional override

# ===========================
# TELEGRAM INTEGRATION (optional)
# ===========================
# Enables vendor notifications + interactive actions via Telegram.
# When TELEGRAM_BOT_TOKEN is unset the entire feature is dormant
# (webhook returns 404, UI shows "próximamente").
# Setup runbook: docs/runbooks/telegram-setup.md
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_WEBHOOK_SECRET=""          # long random string; Telegram echoes it
# TELEGRAM_BOT_USERNAME=""            # @handle, used to build t.me/<bot>?start=<token>

# ===========================
# PUSH NOTIFICATIONS (optional)
# ===========================
# Generate VAPID keys with: npx web-push generate-vapid-keys
# Required only when you want browser push. Leave blank to disable.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY="BL..."
# VAPID_PRIVATE_KEY="..."

# ===========================
# ADMIN HOST ISOLATION (optional)
# ===========================
# Serve /admin/** on a dedicated host so an admin session cookie cannot
# escape to the public storefront. See docs/admin-host.md for the full
# setup (DNS, TLS, verification steps). Leave unset in local dev.
# ADMIN_HOST="admin.your-domain.com"

# ===========================
# PROXY TRUST (self-hosted prod)
# ===========================
# Set to "true" in production when the app runs behind a trusted reverse
# proxy (Traefik, nginx, Caddy, etc.) that strips client-supplied
# x-forwarded-for headers and injects the real client IP. Without this,
# getClientIP() buckets every request as "untrusted-client" and per-IP
# rate limits become a global lockout — one brute-force attempt locks
# out every user on the site.
#
# On Vercel this is unnecessary (VERCEL=1 is auto-detected as trusted).
# On any other production deploy, the boot throws if neither is set.
TRUST_PROXY_HEADERS="false"

# ===========================
# PHOTO STORAGE
# ===========================
# Vercel Blob token — when set, uploads go to Vercel Blob and the
# orphan-cleanup helper can call del() on removed photos. When unset,
# uploads fall back to local `public/uploads/` (dev/test only).
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
#
# Orphan-blob sweeper (#1050). The nightly sweep lists every blob in
# Vercel Blob, crosses it with Product.images / Vendor.logo /
# Vendor.coverImage, and reports anything unreferenced. Default is
# DRY-RUN — set to 'false' to enable real deletes after verifying the
# orphans_found count looks sane. See docs/runbooks/photo-storage.md.
PHOTO_SWEEP_DRY_RUN="true"

# ===========================
# NOTES
# ===========================
# For development: use .env.local (git-ignored)
# For testing: use .env.test
# Never commit real secrets!
